{
  "position": "top",
  "layer": "top",
  "modules-left": ["custom/launcher","hyprland/workspaces"],
  //"modules-center": ["hyprland/window"],
  "modules-right": [
    "cpu",
    "memory",
    "network",
    "pulseaudio",
    "temperature",
    //"battery",
    "keyboard-state",
    "tray",
    "battery",
    "clock",
    "custom/power",
  ],
  // Modules configuration
  "hyprland/workspaces": {
    "all-outputs": true,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1"
  },
  "custom/power": {
    "format": "≤░Ρξ",
    "on-click": "shutdown now"
  },
  "clock": {
    "format": "{:%H:%M} ",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%Y-%m-%d}"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "≤░ΓΕ {capacity}%",
    "format-plugged": "≤░ΓΕ {capacity}%",
    "format-alt": "{time} {icon}",
    "format-full": "≤▒ΙΣ {capacity}%",
    "format-icons": ["≤▒Λκ", "≤▒Λλ", "≤▒Λμ"]
  },
 "cpu": {
    "format": " ΎΜδ {usage}%",
    "tooltip": false
  },
  "memory": {
    "format": "≤░Ξδ {}%"
  },
  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
    "critical-threshold": 80,
    "format": "{icon} {temperatureC}┬░C",
    "format-icons": ["Ύζτ", "ΎΜΚ", "Ύζσ"],
    "interval": 3
  },
  "network": {
    "format-wifi": "ΎΘτ  {essid}",
    "format-ethernet": "ΎηΨ {ipaddr}",
    "format-linked": "{ifname} (No IP) ΎηΨ",
    "format-disconnected": "≤░νχ Disconnected",
    "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },
  "network": {
    "format": "{ifname}",
    "format-wifi": "{essid} ({signalStrength}%) ΎΘτ ",
    "format-ethernet": "ΎηΨ{ipaddr}",
    "format-disconnected": "", //An empty format will hide the module.
    "tooltip-format": "{ifname} via {gwaddr} ΎηΨ",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ΎΘτ",
    "tooltip-format-ethernet": "{ifname} ΎΔΒ",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
  },
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "ΎΕε {name} {icon}",
  },
  "tray": {
       "icon-size": 20,
       "spacing": 10
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "≤░ΨΒ Muted",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "ΎΨΡ",
      "headset": "ΎΨΡ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "pavucontrol"
  },
  "hyprland/window": {  
    "format": "{}",
    "format-stopped": "",
  },
  "custom/launcher":{
    "format": "ΎΝΔ ",
    // "on-click": "wofi --show drun -I -a",
    // "on-click-right": "killall wofi"
  },
}

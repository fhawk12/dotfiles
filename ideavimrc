" Opt
set scrolloff=0
set number
set relativenumber
set clipboard+=unnamedplus
set nowrap
set hlsearch
set incsearch
set smartcase
set ignorecase
set keep-english-in-normal

" Plugins
Plug 'preservim/nerdtree'
Plug 'tpope/vim-surround'ctivateTerminalToolWindow
Plug 'tpope/vim-commentary'
Plug 'machakann/vim-highlightedyank'

" Maps
let mapleader=" "
let maplocalleader=";"

" basic
nnoremap <esc> :noh<cr>
nnoremap gl $
nnoremap gh 0
nnoremap <leader>wd <C-w>c
nnoremap <leader>q :bd<cr>
nnoremap J 5j
nnoremap K 5k
nnoremap L :bp<cr>
nnoremap H :bn<cr>
nnoremap <leader>q :bd<cr>

inoremap <C-f> <right>
inoremap <C-b> <left>

vnoremap J 5j
vnoremap K 5k

nnoremap <C-j> <C-W>j
nnoremap <C-k> <C-W>k
nnoremap <C-h> <C-W>h
nnoremap <C-l> <C-W>l

vnoremap gl $
vnoremap gh 0

" action
nnoremap <leader>fm :action ReformatCode<cr>

" Tree
nnoremap <leader>e :NERDTreeFocus<CR>

nnoremap <leader>rn :action RenameElement<CR>
nnoremap ]d :action GotoNextError<CR>
